---
import SkillsGlobe from "./SkillsGlobe.tsx";

const skills = [
    "Python",
    "LLMs",
    "RAG",
    "Java",
    "React",
    "Spring Boot",
    "C#",
    "SQL Server",
    "SAP HANA",
];
---

<section id="educacion-skills" class="reveal py-20 px-6 sm:px-12 md:px-24">
    <div
        class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16"
    >
        {/* Left Column: Education & Certifications */}
        <div class="space-y-12">
            {/* Education */}
            <div>
                <h2
                    class="text-3xl font-bold mb-8 text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-500 flex items-center gap-3"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="url(#blue-emerald)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <defs>
                            <linearGradient
                                id="blue-emerald"
                                x1="0%"
                                y1="0%"
                                x2="100%"
                                y2="0%"
                            >
                                <stop offset="0%" stop-color="#60A5FA"></stop>
                                <stop offset="100%" stop-color="#10B981"></stop>
                            </linearGradient>
                        </defs>
                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path><path
                            d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"></path>
                    </svg>
                    Educación
                </h2>

                <div
                    class="bg-slate-800/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 sm:p-8 hover:bg-slate-800/60 transition-colors shadow-lg group relative overflow-hidden"
                >
                    {/* Neon subtle background */}
                    <div
                        class="absolute -right-10 -top-10 w-32 h-32 bg-sky-500/10 rounded-full blur-2xl group-hover:bg-sky-500/20 transition-all"
                    >
                    </div>

                    <h3
                        class="text-xl sm:text-2xl font-bold text-slate-100 group-hover:text-sky-300 transition-colors mb-2"
                    >
                        Ingeniería en Sistemas Computacionales
                    </h3>
                    <h4 class="text-lg font-medium text-emerald-400 mb-3">
                        Instituto Tecnológico de Mérida
                    </h4>
                    <div
                        class="flex items-center text-slate-400 text-sm font-medium"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="mr-2"
                            ><rect
                                width="18"
                                height="18"
                                x="3"
                                y="4"
                                rx="2"
                                ry="2"></rect><line
                                x1="16"
                                x2="16"
                                y1="2"
                                y2="6"></line><line x1="8" x2="8" y1="2" y2="6"
                            ></line><line x1="3" x2="21" y1="10" y2="10"
                            ></line></svg
                        >
                        2016 - 2022
                    </div>
                </div>
            </div>

            {/* Certifications */}
            <div>
                <h2
                    class="text-3xl font-bold mb-8 text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-500 flex items-center gap-3"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="url(#blue-emerald-cert)"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <defs>
                            <linearGradient
                                id="blue-emerald-cert"
                                x1="0%"
                                y1="0%"
                                x2="100%"
                                y2="0%"
                            >
                                <stop offset="0%" stop-color="#60A5FA"></stop>
                                <stop offset="100%" stop-color="#10B981"></stop>
                            </linearGradient>
                        </defs>
                        <circle cx="12" cy="8" r="6"></circle><path
                            d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path>
                    </svg>
                    Certificaciones Destacadas
                </h2>

                <div class="space-y-4">
                    <div
                        class="bg-slate-800/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 sm:p-7 hover:bg-slate-800/60 transition-colors shadow-sm hover:shadow-md group"
                    >
                        <h3
                            class="text-lg sm:text-xl font-bold text-slate-100 group-hover:text-sky-300 transition-colors mb-2 leading-tight"
                        >
                            Ingeniería de LLM: Domina IA, Modelos de Lenguaje y
                            Agentes
                        </h3>
                        <div
                            class="flex flex-wrap items-center text-slate-400 text-sm font-medium gap-3"
                        >
                            <span class="text-emerald-400">Udemy</span>
                            <span class="w-1.5 h-1.5 rounded-full bg-slate-600"
                            ></span>
                            <span>feb. 2026</span>
                        </div>
                    </div>

                    <div
                        class="bg-slate-800/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 sm:p-7 hover:bg-slate-800/60 transition-colors shadow-sm hover:shadow-md group"
                    >
                        <h3
                            class="text-lg sm:text-xl font-bold text-slate-100 group-hover:text-sky-300 transition-colors mb-2 leading-tight"
                        >
                            React & Spring Boot: Creando Webapp Full Stack
                        </h3>
                        <div
                            class="flex flex-wrap items-center text-slate-400 text-sm font-medium gap-3"
                        >
                            <span class="text-emerald-400">Udemy</span>
                            <span class="w-1.5 h-1.5 rounded-full bg-slate-600"
                            ></span>
                            <span>ene. 2025</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {/* Right Column: Skills */}
        <div>
            <h2
                class="text-3xl font-bold mb-8 text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-500 flex items-center gap-3"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="url(#blue-emerald-skills)"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <defs>
                        <linearGradient
                            id="blue-emerald-skills"
                            x1="0%"
                            y1="0%"
                            x2="100%"
                            y2="0%"
                        >
                            <stop offset="0%" stop-color="#60A5FA"></stop>
                            <stop offset="100%" stop-color="#10B981"></stop>
                        </linearGradient>
                    </defs>
                    <path d="m18 16 4-4-4-4"></path><path d="m6 8-4 4 4 4"
                    ></path><path d="m14.5 4-5 16"></path>
                </svg>
                Skills & Tecnologías
            </h2>

            <div
                class="relative h-full min-h-[400px] flex flex-col justify-center"
            >
                <div
                    class="flex justify-center relative z-10 w-full overflow-hidden"
                >
                    <SkillsGlobe client:load />
                </div>
            </div>
        </div>
    </div>
</section>
