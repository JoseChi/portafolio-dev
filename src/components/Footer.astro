---
const currentYear = new Date().getFullYear();
---

<footer class="bg-slate-950/50 pt-16 pb-8 border-t border-slate-800/60 mt-20">
  <div class="max-w-6xl mx-auto px-6 sm:px-12 md:px-24">
    <div class="flex flex-col items-center">
      
      {/* Brand/Logo (Optional but nice) */}
      <div class="mb-6">
        <span class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500">
            JACM
        </span>
      </div>

      <p class="text-slate-400 text-center text-sm md:text-base">
        &copy; {currentYear} Jose Antonio Chi May. Todos los derechos reservados.
      </p>
      
      <div class="flex gap-6 justify-center mt-6">
        <a 
            href="https://www.linkedin.com/in/jose-antonio-chi-may/" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-sm font-medium text-slate-400 hover:text-indigo-400 hover:drop-shadow-[0_0_8px_rgba(99,102,241,0.5)] transition-all duration-300"
        >
            LinkedIn
        </a>
        <a 
            href="https://github.com/AntaresCh" 
            target="_blank" 
            rel="noopener noreferrer"
            class="text-sm font-medium text-slate-400 hover:text-purple-400 hover:drop-shadow-[0_0_8px_rgba(168,85,247,0.5)] transition-all duration-300"
        >
            GitHub
        </a>
        <a 
            href="mailto:tu-correo@ejemplo.com" 
            class="text-sm font-medium text-slate-400 hover:text-blue-400 hover:drop-shadow-[0_0_8px_rgba(96,165,250,0.5)] transition-all duration-300"
        >
            Email
        </a>
      </div>
      
    </div>
  </div>
</footer>
