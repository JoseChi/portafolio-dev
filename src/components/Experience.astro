---
import { getCollection } from 'astro:content';

const experiences = await getCollection('experience');
const sortedExperiences = experiences.sort((a, b) => a.data.order - b.data.order);
---

<section id="experiencia" class="reveal py-20 px-6 sm:px-12 md:px-24">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-12 text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500">
      Experiencia Profesional
    </h2>
    
    <div class="relative border-l-2 border-slate-700 ml-4 md:ml-6 space-y-12">
      {sortedExperiences.map(async (exp) => {
        const { Content } = await exp.render();
        return (
          <div class="relative pl-8 md:pl-10">
            {/* Timeline dot */}
            <div class="absolute -left-[9px] top-1.5 w-4 h-4 bg-indigo-500 rounded-full shadow-[0_0_15px_rgba(99,102,241,0.8)] border-[3px] border-slate-900 z-10"></div>
            
            {/* Content card */}
            <div class="bg-slate-800/40 backdrop-blur-sm border border-slate-700/50 rounded-2xl p-6 sm:p-8 hover:bg-slate-800/60 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] shadow-lg hover:shadow-indigo-500/20 hover:border-indigo-500/50 group">
              <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-2 gap-2">
                <h3 class="text-xl sm:text-2xl font-bold text-slate-100 group-hover:text-indigo-300 transition-colors">
                  {exp.data.role}
                </h3>
                <span class="text-sm font-medium text-indigo-400 bg-indigo-500/10 px-3 py-1 rounded-full shrink-0 border border-indigo-500/20">
                  {exp.data.period}
                </span>
              </div>
              
              <h4 class="text-lg font-medium text-purple-400 mb-4">
                {exp.data.company}
              </h4>
              
              <div class="text-slate-300 text-base leading-relaxed">
                <Content />
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
