---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.tsx";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Education from "../components/Education.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const description =
	"Explora mi portafolio. Soy José Antonio Chi May, Ingeniero de Software Full Stack y AI Developer con experiencia en Java, React y arquitecturas escalables.";
---

<Layout
	title="Jose Antonio Chi May | Software Engineer & AI Developer"
	description={description}
>
	<main>
		<Hero lang={lang} client:load />
		<Experience />
		<Projects />
		<Education />
		<Contact />
	</main>
	<Footer />
</Layout>
